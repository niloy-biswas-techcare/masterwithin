    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@mw/config": "workspace:*",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "jsdom": "^25.0.0",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "typescript-eslint": "^8.0.0",
