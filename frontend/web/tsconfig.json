{
  "extends": "@mw/config/tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@mw/ui/fonts": ["../../packages/ui/src/fonts.ts"],
      "@mw/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts", "src/sw.ts"],
  "exclude": ["node_modules"]
}
